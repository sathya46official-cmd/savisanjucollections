# Backend API URL (Express server)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Backend API Hostname (for next/image optimization)
# TODO: Set to your Oracle VPS domain in production (e.g., api.savisanju.com or VPS IP)
NEXT_PUBLIC_API_HOSTNAME=localhost

# Business Contact Information
# TODO: Replace with your real WhatsApp business number (format: country code + number, no spaces/dashes)
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# TODO: Replace with your Google Business Profile ID (get from https://business.google.com)
# Leave as placeholder to hide the "Rate on Google" button until you have a real ID
NEXT_PUBLIC_GOOGLE_BUSINESS_ID=YOUR_GOOGLE_BUSINESS_ID

# Google Analytics 4 (SEO / Traffic Tracking)
# Get this from: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
